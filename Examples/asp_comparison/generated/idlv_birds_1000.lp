penguin(p1).

bird(X) :- penguin(X).
flies(X) :- bird(X), not nonflies(X).
nonflies(X) :- penguin(X).

anc(X,Y) :- father(X,Y).
anc(X,Y) :- anc(X,Z), anc(Z,Y).

penguin(X) :- anc(Y,X), penguin(Y).
bird(X) :- anc(Y,X), bird(Y).

