% The basic birds example in GKP, the Prolog/ProbLog-style surface language.
% This is a 1:1 translation of bird_penguin.js: gk converts it to the same
% JSON-LD-LOGIC before proving. See Doc/input_languages.md.

bird(b).
0.8::penguin(p).

bird(X) :- penguin(X).
0.9::-flies(X) :- penguin(X).
flies(X) :- bird(X), unless(-flies(X), 2).

query(-flies(X)).
